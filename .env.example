APP_NAME="Inventory Pro"
APP_URL=http://localhost:8000
APP_ENV=development
APP_DEBUG=true

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=product_inventory_management_system
DB_USERNAME=root
DB_PASSWORD=

SESSION_LIFETIME=120

DASHBOARD_REPORT_MONTHS=6
LOW_STOCK_THRESHOLD=5

AUTH_MAX_ATTEMPTS=3
AUTH_LOCK_MINUTES=15
AUTH_OTP_EXPIRY_MINUTES=10
AUTH_DEFAULT_STAFF_ROLE_ID=3

MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Inventory Pro"